FROM ros:humble-ros-base

ENV DEBIAN_FRONTEND=noninteractive
ENV ROS_DISTRO=humble

# ─── Add Gazebo Fortress repo ──────────────────────────────────────
RUN apt-get update && apt-get install -y curl gnupg lsb-release && \
    curl -sSL https://packages.osrfoundation.org/gazebo.gpg \
    -o /usr/share/keyrings/pkgs-osrf-archive-keyring.gpg && \
    echo "deb [arch=amd64 signed-by=/usr/share/keyrings/pkgs-osrf-archive-keyring.gpg] \
    http://packages.osrfoundation.org/gazebo/ubuntu-stable jammy main" \
    > /etc/apt/sources.list.d/gazebo-stable.list

RUN apt-get update && apt-get install -y \
    python3-pip \
    python3-colcon-common-extensions \
    python3-rosdep \
    python3-argcomplete \
    git wget curl \
    # Nav2
    ros-humble-navigation2 \
    ros-humble-nav2-bringup \
    # RTAB-Map
    ros-humble-rtabmap-ros \
    # EKF
    ros-humble-robot-localization \
    # MoveIt2
    ros-humble-moveit \
    ros-humble-moveit-ros-planning-interface \
    ros-humble-moveit-setup-assistant \
    ros-humble-warehouse-ros \
    ros-humble-moveit-ros-perception \ 
    ros-humble-moveit-ros-occupancy-map-monitor \
    # ros2_control
    ros-humble-ros2-control \
    ros-humble-ros2-controllers \
    # OAK-D
    # ros-humble-depthai-ros \
    # Robot description
    ros-humble-xacro \
    ros-humble-joint-state-publisher \
    ros-humble-joint-state-publisher-gui \
    ros-humble-robot-state-publisher \
    # Gazebo Fortress + ROS2 bridge
    ros-humble-ros-gz \
    ros-humble-ign-ros2-control \
    ignition-fortress \
    # Laser filters
    ros-humble-laser-filters \
    # Joystick teleop
    ros-humble-joy \
    ros-humble-teleop-twist-joy \
    # Visualization
    ros-humble-rviz2 \
    ros-humble-rqt \
    ros-humble-rqt-common-plugins \
    # Debug tools
    ros-humble-teleop-twist-keyboard \
    ros-humble-topic-tools \
    && rm -rf /var/lib/apt/lists/*

# PyTorch with CUDA 11.8
RUN pip3 install \
    torch torchvision \
    --index-url https://download.pytorch.org/whl/cu118

RUN pip3 install --no-cache-dir --default-timeout=1000 numpy Pillow
RUN pip3 install --no-cache-dir --default-timeout=1000 opencv-python-headless
RUN pip3 install --no-cache-dir --default-timeout=1000 ultralytics  

# WSLg display support
ENV DISPLAY=:0
ENV WAYLAND_DISPLAY=wayland-0
ENV XDG_RUNTIME_DIR=/tmp/runtime-root
ENV LIBGL_ALWAYS_SOFTWARE=0

WORKDIR /cika_ws

COPY cika_ws/src/ src/
COPY cika_ws/config/ config/
COPY cika_ws/models/ models/

RUN rosdep init || true && \
    rosdep update && \
    rosdep install --from-paths src \
    --ignore-src -r -y \
    --skip-keys="warehouse_ros_mongo"

RUN . /opt/ros/humble/setup.sh && \
    colcon build \
    --symlink-install \
    --cmake-args -DCMAKE_BUILD_TYPE=Release

RUN echo "source /opt/ros/humble/setup.bash" >> ~/.bashrc && \
    echo "source /cika_ws/install/setup.bash" >> ~/.bashrc && \
    echo "export ROS_DOMAIN_ID=0" >> ~/.bashrc && \
    echo "export RMW_IMPLEMENTATION=rmw_fastrtps_cpp" >> ~/.bashrc

COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]