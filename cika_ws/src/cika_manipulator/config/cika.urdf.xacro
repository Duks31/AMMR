<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="cika">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import cika urdf file -->
    <xacro:include filename="$(find cika_description)/urdf/cika.xacro" />

    <!-- Import control_xacro -->
    <xacro:include filename="cika.ros2_control.xacro" />


    <xacro:cika_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
