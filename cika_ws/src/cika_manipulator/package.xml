<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
    <name>cika_manipulator</name>
    <version>0.3.0</version>
    <description> An automatically generated package with all the configuration and launch files for
        using the cika with the MoveIt Motion Planning Framework </description>
    <maintainer email="kenechukwuanakwue@gmail.com"></maintainer>
    <license>BSD</license>
    <buildtool_depend>ament_cmake</buildtool_depend>
    <build_depend>rosidl_default_generators</build_depend>
    <depend>std_msgs</depend>
    <depend>action_msgs</depend>
    <!-- Core MoveIt2 — needed for planning and execution -->
    <exec_depend>moveit_ros_move_group</exec_depend>
    <exec_depend>moveit_kinematics</exec_depend>
    <exec_depend>moveit_planners</exec_depend>
    <exec_depend>moveit_simple_controller_manager</exec_depend>
    <exec_depend>moveit_configs_utils</exec_depend>
    <!-- Robot description -->
    <exec_depend>cika_description</exec_depend>
    <exec_depend>robot_state_publisher</exec_depend>
    <exec_depend>joint_state_publisher</exec_depend>
    <exec_depend>controller_manager</exec_depend>
    <exec_depend>xacro</exec_depend>
    <exec_depend>tf2_ros</exec_depend>
    <exec_depend>rosidl_default_runtime</exec_depend>
    <!-- Removed for Pi: rviz2, rviz_common, rviz_default_plugins,
       moveit_setup_assistant, moveit_ros_visualization,
       moveit_ros_warehouse, warehouse_ros_mongo,
       joint_state_publisher_gui -->
    <test_depend>ament_lint_auto</test_depend>
    <test_depend>ament_lint_common</test_depend>
    <export>
        <build_type>ament_cmake</build_type>
        <member_of_group>rosidl_interface_packages</member_of_group>
    </export>
</package>